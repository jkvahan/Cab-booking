rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: admins
    // Fields: username, password, pin, role
    //
    // Collection: users
    // Fields: name, phone, password, created_at
    //
    // Collection: drivers
    // Fields: name, phone, password, status, wallet_balance, is_online
    //
    // Collection: vehicles
    // Fields: driver_id, model, plate_number, type
    //
    // Collection: rides
    // Fields: tracking_id, pickup_location, dropoff_location, status, fare, driver_id, user_id, ...
    //
    // Collection: transactions
    // Fields: driver_id, amount, type, description, created_at
    //
    // Collection: withdrawal_requests
    // Fields: driver_id, amount, bank_details, status, created_at
    //
    // Collection: notifications
    // Fields: message, target, driver_id, created_at, read_by
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    // Since the app uses a custom auth system, we'll allow limited public access
    // for login and registration, but we should warn the user to use Firebase Auth.
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role in ['admin', 'owner'] ||
          (request.auth.token.email == "digitalserviceindia84@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'owner' ||
          (request.auth.token.email == "digitalserviceindia84@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 15 &&
             data.password is string && data.password.size() > 0;
    }

    function isValidDriver(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 15 &&
             data.password is string && data.password.size() > 0 &&
             data.status in ['active', 'inactive', 'pending'];
    }

    function isValidRide(data) {
      return data.tracking_id is string &&
             data.pickup_location is string &&
             data.dropoff_location is string &&
             data.status in ['pending', 'accepted', 'ongoing', 'completed', 'cancelled'] &&
             data.fare is number &&
             (!('pickup_date' in data) || data.pickup_date is string) &&
             (!('pickup_time' in data) || data.pickup_time is string);
    }

    function isValidAdmin(data) {
      return data.username is string && data.username.size() > 0 &&
             data.password is string && data.password.size() > 0 &&
             data.pin is string && data.pin.matches("^\\d{4}$") &&
             data.role in ['admin', 'owner'];
    }

    function isValidNotification(data) {
      return data.message is string && data.message.size() > 0 && data.message.size() < 1000 &&
             data.target in ['all_drivers', 'all_users', 'specific_driver'] &&
             (!('driver_id' in data) || data.driver_id is string) &&
             data.created_at is string &&
             data.read_by is list;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /admins/{adminId} {
      // Allow public read for login (limit 1)
      allow read: if isOwner() || (request.query.limit <= 1) || (isAuthenticated() && request.auth.uid == adminId);
      allow write: if isOwner();
    }

    match /users/{userId} {
      // Allow public read only for login check (limit 1)
      allow read: if isAdmin() || isOwner() || (request.query.limit <= 1) || (isAuthenticated() && request.auth.uid == userId); 
      allow create: if isValidUser(request.resource.data);
      allow update: if isAdmin() || isOwner() || (isAuthenticated() && request.auth.uid == userId);
    }

    match /drivers/{driverId} {
      // Allow public read only for login check (limit 1)
      allow read: if isAdmin() || isOwner() || (request.query.limit <= 1) || (isAuthenticated() && request.auth.uid == driverId);
      allow create: if isValidDriver(request.resource.data);
      allow update: if isAdmin() || isOwner() || (isAuthenticated() && request.auth.uid == driverId);
    }

    match /vehicles/{vehicleId} {
      allow read: if isAdmin() || isOwner() || (isAuthenticated() && resource.data.driver_id == request.auth.uid);
      allow write: if isAdmin() || isOwner() || (isAuthenticated() && request.resource.data.driver_id == request.auth.uid);
    }

    match /rides/{rideId} {
      allow read: if isAdmin() || isOwner() || (isAuthenticated() && (resource.data.user_id == request.auth.uid || resource.data.driver_id == request.auth.uid || resource.data.status == 'pending'));
      allow create: if isValidRide(request.resource.data);
      allow update: if isAdmin() || isOwner() || (isAuthenticated() && (resource.data.user_id == request.auth.uid || resource.data.driver_id == request.auth.uid || (resource.data.status == 'pending' && request.resource.data.status == 'accepted')));
    }

    match /transactions/{transactionId} {
      allow read: if isAdmin() || isOwner() || (isAuthenticated() && resource.data.driver_id == request.auth.uid);
      allow write: if isAdmin() || isOwner();
    }

    match /withdrawal_requests/{requestId} {
      allow read: if isAdmin() || isOwner() || (isAuthenticated() && resource.data.driver_id == request.auth.uid);
      allow create: if true; // Allow drivers to request
      allow update: if isAdmin() || isOwner();
    }

    match /notifications/{notificationId} {
      allow read: if isAdmin() || isOwner() || isAuthenticated();
      allow create: if isAdmin() || isOwner();
      allow update: if isAdmin() || isOwner() || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read_by']));
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
